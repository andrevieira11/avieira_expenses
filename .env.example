# =====================================================================
# Saldo environment. Copy to .env and fill in. NEVER commit .env.
# Generate secrets with:  openssl rand -base64 32   (and  openssl rand -hex 32)
# Legend: [SECRET] never commit/share  [PUBLIC] shipped to browser  [CONFIG] non-sensitive
# =====================================================================

# ---- Postgres (the db service) ----
POSTGRES_USER=saldo                              # [CONFIG]
POSTGRES_PASSWORD=change-me-strong-random         # [SECRET] openssl rand -base64 24
POSTGRES_DB=saldo                                # [CONFIG]

# ---- App DB connection (app + migrate). Host "db" = the compose service. ----
# Password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://saldo:change-me-strong-random@db:5432/saldo?sslmode=disable   # [SECRET]

# ---- Better Auth ----
BETTER_AUTH_SECRET=change-me-32-byte-random       # [SECRET] openssl rand -base64 32
BETTER_AUTH_URL=https://saldo.your-domain.tld     # [CONFIG] public canonical origin

# ---- Public app URL (INLINED into the client bundle at BUILD time) ----
NEXT_PUBLIC_APP_URL=https://saldo.your-domain.tld # [PUBLIC]

# ---- moey! ingest webhook (also gates the bank-sync cron) ----
INGEST_WEBHOOK_TOKEN=change-me-long-random-token  # [SECRET] openssl rand -hex 32

# ---- Open Banking (Enable Banking — auto-imports moey!/Crédito Agrícola transactions) ----
# Free for personal use. Register an app at https://enablebanking.com/sign-in (Control Panel
# -> API applications -> Production); the browser downloads <app-id>.pem and shows the App ID.
# Encode the key for env:  base64 -w0 <app-id>.pem      (macOS: base64 -i <app-id>.pem)
# Leave blank to disable bank sync (the moey! Shortcut still works).
ENABLEBANKING_APP_ID=                             # [CONFIG] application UUID (the kid)
ENABLEBANKING_PEM_BASE64=                         # [SECRET] base64 of the .pem private key

# ---- Host port the app publishes (Caddy proxies to this) ----
APP_PORT=3000                                     # [CONFIG]

# ---- Web push (PWA notifications). Generate: npx web-push generate-vapid-keys ----
VAPID_PUBLIC_KEY=                                 # [CONFIG]
VAPID_PRIVATE_KEY=                                # [SECRET]
VAPID_SUBJECT=mailto:you@your-domain.tld          # [CONFIG]
